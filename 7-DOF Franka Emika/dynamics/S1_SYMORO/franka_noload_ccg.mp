<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No16:=(-DV226 + DV336)*I6yz + DV236*PIS16 + I6xz*U216 - I6xy*U316 + I6xx*WP16;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No26:=(DV116 - DV336)*I6xz + DV136*PIS26 - I6yz*U126 + I6xy*U326 + I6yy*WP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No36:=(-DV116 + DV226)*I6xy + DV126*PIS36 + I6yz*U136 - I6xz*U236 - I6zz*WP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI17:=S7*W36 + C7*WI16;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI27:=C7*W36 - S7*WI16;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">W37:=qd7 - WI26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP17:=qd7*WI27 + C7*WP16 - S7*WP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP27:=-(qd7*WI17) - S7*WP16 - C7*WP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV117:=-WI17^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV227:=-WI27^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV337:=-W37^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV127:=WI17*WI27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV137:=W37*WI17;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV237:=W37*WI27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U117:=DV227 + DV337;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U127:=DV127 + WP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U137:=DV137 + WP27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U217:=DV127 - WP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U227:=DV117 + DV337;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U237:=DV237 - WP17;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U317:=DV137 - WP27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U327:=DV237 + WP17;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U337:=DV117 + DV227;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP17:=L3*U116 + VP16;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP27:=L3*U216 + VP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP37:=L3*U316 - VP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP17:=C7*VSP17 + S7*VSP37;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP27:=-(S7*VSP17) + C7*VSP37;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F17:=mx7*U117 + my7*U127 + mz7*U137 + m7*VP17;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F27:=mx7*U217 + my7*U227 + mz7*U237 + m7*VP27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F37:=mx7*U317 + my7*U327 + mz7*U337 - m7*VSP27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS17:=-I7yy + I7zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS27:=I7xx - I7zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS37:=-I7xx + I7yy;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No17:=(-DV227 + DV337)*I7yz + DV237*PIS17 + I7xz*U217 - I7xy*U317 + I7xx*WP17;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No27:=(DV117 - DV337)*I7xz + DV137*PIS27 - I7yz*U127 + I7xy*U327 + I7yy*WP27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No37:=(-DV117 + DV227)*I7xy + DV127*PIS37 + I7yz*U137 - I7xz*U237 - I7zz*WP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N17:=No17 - mz7*VP27 - my7*VSP27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N27:=No27 + mz7*VP17 + mx7*VSP27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N37:=No37 - my7*VP17 + mx7*VP27;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI17:=C7*F17 - F27*S7;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI37:=C7*F27 + F17*S7;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E16:=F16 + FDI17;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E26:=F26 - F37;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E36:=F36 + FDI37;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N16:=C7*N17 + No16 - N27*S7 - my6*VP25 - mz6*VP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N26:=-(FDI37*L3) - N37 + No26 + mz6*VP16 + mx6*VP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N36:=-(F37*L3) + C7*N27 + No36 + N17*S7 - my6*VP16 + mx6*VP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI16:=C6*E16 - E26*S6;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI36:=C6*E26 + E16*S6;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E15:=F15 + FDI16;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E25:=-E36 + F25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E35:=F35 + FDI36;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N15:=C6*N16 + No15 - N26*S6 - mz5*VP25 + my5*VSP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N25:=-N36 + No25 + mz5*VP15 - mx5*VSP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N35:=C6*N26 + No35 + N16*S6 - my5*VP15 + mx5*VP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI15:=C5*E15 - E25*S5;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI35:=-(C5*E25) - E15*S5;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E14:=F14 + FDI15;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E24:=E35 + F24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E34:=F34 + FDI35;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N14:=FDI35*L6 + C5*N15 + No14 - N25*S5 - mz4*VP24 - my4*VSP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N24:=-(FDI35*L2) + N35 + No24 + mz4*VP14 + mx4*VSP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N34:=E35*L2 - FDI15*L6 - C5*N25 + No34 - N15*S5 - my4*VP14 + mx4*VP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI14:=C4*E14 - E24*S4;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI34:=C4*E24 + E14*S4;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E13:=F13 + FDI14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">E23:=-E34 + F23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N13:=C4*N14 + No13 - N24*S4 - mz3*VP23 - my3*VSP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N23:=-(FDI34*L1) - N34 + No23 + mz3*VP13 + mx3*VSP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N33:=-(E34*L1) + C4*N24 + No33 + N14*S4 - my3*VP13 + mx3*VP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI13:=C3*E13 - E23*S3;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">FDI33:=C3*E23 + E13*S3;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N12:=-(FDI33*L5) + C3*N13 + No12 - N23*S3 - mz2*VP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N22:=-N33 + No22 + mz2*VP12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N32:=FDI13*L5 + C3*N23 + No32 + N13*S3 - my2*VP12 + mx2*VP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">N31:=-(C2*N22) - N12*S2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">H1:=N31 + Fv1*qd1 + Fc1*sign(qd1);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">H2:=N32 + Fv2*qd2 + Fc2*sign(qd2);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">H3:=N33 + Fv3*qd3 + Fc3*sign(qd3);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">H4:=N34 + Fv4*qd4 + Fc4*sign(qd4);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">H5:=N35 + Fv5*qd5 + Fc5*sign(qd5);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">H6:=N36 + Fv6*qd6 + Fc6*sign(qd6);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">H7:=N37 + Fv7*qd7 + Fc7*sign(qd7);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># *=*</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Number of operations : 360 '+' or '-', 370 '*' or '/'</Text-field>
</Group>
</Worksheet>