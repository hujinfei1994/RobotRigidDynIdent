<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U236:=DV236 - WP16;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U316:=DV136 - WP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U326:=DV236 + WP16;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U336:=DV116 + DV226;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP16:=C6*VP15 + S6*VSP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP26:=-(S6*VP15) + C6*VSP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F16:=mx6*U116 + my6*U126 + mz6*U136 + m6*VP16;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F26:=mx6*U216 + my6*U226 + mz6*U236 + m6*VP26;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F36:=mx6*U316 + my6*U326 + mz6*U336 - m6*VP25;</Text-field>
