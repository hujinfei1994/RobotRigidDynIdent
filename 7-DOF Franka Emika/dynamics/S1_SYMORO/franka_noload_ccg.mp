<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 2      0      0      0      0      0      0      Fc2    Fv2    qd2    qdd2</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 3      0      0      0      0      0      0      Fc3    Fv3    qd3    qdd3</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 4      0      0      0      0      0      0      Fc4    Fv4    qd4    qdd4</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 5      0      0      0      0      0      0      Fc5    Fv5    qd5    qdd5</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 6      0      0      0      0      0      0      Fc6    Fv6    qd6    qdd6</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 7      0      0      0      0      0      0      Fc7    Fv7    qd7    qdd7</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Base velocity, base accelerations, and gravity</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># j     W0    WP0   V0    VP0   G</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 1     0     0     0     0     0</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 2     0     0     0     0     0</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># 3     0     0     0     0     g</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">#   Centrifugal, Coriolis and gravity Torque</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"></Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal"># Equations:</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">S2:=sin(q2);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">C2:=cos(q2);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">S3:=sin(q3);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">C3:=cos(q3);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">S4:=sin(q4);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">C4:=cos(q4);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">S5:=sin(q5);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">C5:=cos(q5);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">S6:=sin(q6);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">C6:=cos(q6);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">S7:=sin(q7);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">C7:=cos(q7);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI12:=-(qd1*S2);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI22:=-(C2*qd1);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP12:=qd2*WI22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP22:=-(qd2*WI12);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV112:=-WI12^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV222:=-WI22^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV332:=-qd2^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV122:=WI12*WI22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV132:=qd2*WI12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV232:=qd2*WI22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U132:=DV132 + WP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U222:=DV112 + DV332;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U232:=DV232 - WP12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U312:=DV132 - WP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U322:=DV232 + WP12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP12:=g*S2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP22:=C2*g;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS12:=-I2yy + I2zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS22:=I2xx - I2zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS32:=-I2xx + I2yy;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No12:=DV122*I2xz + (-DV222 + DV332)*I2yz + DV232*PIS12 - I2xy*U312 + I2xx*WP12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No22:=(DV112 - DV332)*I2xz - DV122*I2yz + DV132*PIS22 + I2xy*U322 + I2yy*WP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No32:=(-DV112 + DV222)*I2xy + DV122*PIS32 + I2yz*U132 - I2xz*U232;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI13:=qd2*S3 + C3*WI12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI23:=C3*qd2 - S3*WI12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">W33:=qd3 - WI22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP13:=qd3*WI23 + C3*WP12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP23:=-(qd3*WI13) - S3*WP12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV113:=-WI13^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV223:=-WI23^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV333:=-W33^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV123:=WI13*WI23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV133:=W33*WI13;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV233:=W33*WI23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U113:=DV223 + DV333;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U123:=DV123 + WP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U133:=DV133 + WP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U213:=DV123 - WP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U223:=DV113 + DV333;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U233:=DV233 - WP13;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U313:=DV133 - WP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U323:=DV233 + WP13;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP13:=-(DV122*L5) + VP12;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP23:=-(L5*U222) + VP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP33:=-(L5*U322);</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP13:=C3*VSP13 + S3*VSP33;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP23:=-(S3*VSP13) + C3*VSP33;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F13:=mx3*U113 + my3*U123 + mz3*U133 + m3*VP13;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F23:=mx3*U213 + my3*U223 + mz3*U233 + m3*VP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS13:=-I3yy + I3zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS23:=I3xx - I3zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS33:=-I3xx + I3yy;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No13:=(-DV223 + DV333)*I3yz + DV233*PIS13 + I3xz*U213 - I3xy*U313 + I3xx*WP13;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No23:=(DV113 - DV333)*I3xz + DV133*PIS23 - I3yz*U123 + I3xy*U323 + I3yy*WP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No33:=(-DV113 + DV223)*I3xy + DV123*PIS33 + I3yz*U133 - I3xz*U233 - I3zz*WP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI14:=S4*W33 + C4*WI13;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI24:=C4*W33 - S4*WI13;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">W34:=qd4 - WI23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP14:=qd4*WI24 + C4*WP13 - S4*WP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP24:=-(qd4*WI14) - S4*WP13 - C4*WP22;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV114:=-WI14^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV224:=-WI24^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV334:=-W34^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV124:=WI14*WI24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV134:=W34*WI14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV234:=W34*WI24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U114:=DV224 + DV334;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U124:=DV124 + WP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U134:=DV134 + WP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U214:=DV124 - WP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U224:=DV114 + DV334;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U234:=DV234 - WP14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U314:=DV134 - WP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U324:=DV234 + WP14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U334:=DV114 + DV224;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP14:=L1*U113 + VP13;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP24:=L1*U213 + VP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP34:=L1*U313 - VSP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP14:=C4*VSP14 + S4*VSP34;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP24:=-(S4*VSP14) + C4*VSP34;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F14:=mx4*U114 + my4*U124 + mz4*U134 + m4*VP14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F24:=mx4*U214 + my4*U224 + mz4*U234 + m4*VP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F34:=mx4*U314 + my4*U324 + mz4*U334 - m4*VSP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS14:=-I4yy + I4zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS24:=I4xx - I4zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS34:=-I4xx + I4yy;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No14:=(-DV224 + DV334)*I4yz + DV234*PIS14 + I4xz*U214 - I4xy*U314 + I4xx*WP14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No24:=(DV114 - DV334)*I4xz + DV134*PIS24 - I4yz*U124 + I4xy*U324 + I4yy*WP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No34:=(-DV114 + DV224)*I4xy + DV124*PIS34 + I4yz*U134 - I4xz*U234 - I4zz*WP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI15:=-(S5*W34) + C5*WI14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI25:=-(C5*W34) - S5*WI14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">W35:=qd5 + WI24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP15:=qd5*WI25 + C5*WP14 + S5*WP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP25:=-(qd5*WI15) - S5*WP14 + C5*WP23;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV115:=-WI15^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV225:=-WI25^2;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV335:=-W35^2;</Text-field>
