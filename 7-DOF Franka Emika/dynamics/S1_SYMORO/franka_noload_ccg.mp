<Text-field prompt="&gt; " style="Maple Input" layout="Normal">DV235:=W35*WI25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U115:=DV225 + DV335;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U125:=DV125 - WP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U135:=DV135 + WP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U215:=DV125 + WP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U225:=DV115 + DV335;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U235:=DV235 - WP15;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U315:=DV135 - WP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U325:=DV235 + WP15;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">U335:=DV115 + DV225;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP15:=L2*U114 + L6*U124 + VP14;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP25:=L2*U214 + L6*U224 + VP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VSP35:=L2*U314 + L6*U324 - VSP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP15:=C5*VSP15 - S5*VSP35;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">VP25:=-(S5*VSP15) - C5*VSP35;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F15:=mx5*U115 + my5*U125 + mz5*U135 + m5*VP15;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F25:=mx5*U215 + my5*U225 + mz5*U235 + m5*VP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">F35:=mx5*U315 + my5*U325 + mz5*U335 + m5*VSP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS15:=-I5yy + I5zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS25:=I5xx - I5zz;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">PIS35:=-I5xx + I5yy;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No15:=(-DV225 + DV335)*I5yz + DV235*PIS15 + I5xz*U215 - I5xy*U315 + I5xx*WP15;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No25:=(DV115 - DV335)*I5xz + DV135*PIS25 - I5yz*U125 + I5xy*U325 + I5yy*WP25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">No35:=(-DV115 + DV225)*I5xy + DV125*PIS35 + I5yz*U135 - I5xz*U235 + I5zz*WP24;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI16:=S6*W35 + C6*WI15;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WI26:=C6*W35 - S6*WI15;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">W36:=qd6 - WI25;</Text-field>
<Text-field prompt="&gt; " style="Maple Input" layout="Normal">WP16:=qd6*WI26 + C6*WP15 + S6*WP24;</Text-field>
